# Listopad Environment Variables
# Copy to .env.local and fill in your DEV Supabase credentials
#
# For deployed environments, configure these in each Vercel project:
#   - listopad-stage: auto-deploys from main, uses listopad-dev Supabase
#   - listopad-prod:  deploy-hook only, uses listopad-prod Supabase

# =============================================================================
# Required - Supabase Connection
# =============================================================================

# Your Supabase project URL
# Local/Stage: https://<listopad-dev>.supabase.co
# Prod:        https://<listopad-prod>.supabase.co
NEXT_PUBLIC_SUPABASE_URL=

# Your Supabase anon (public) key
# Found in: Supabase Dashboard > Project Settings > API > anon key
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# =============================================================================
# Optional - Admin/Seeding
# =============================================================================

# Service role key for admin operations (seeding, migrations)
# Found in: Supabase Dashboard > Project Settings > API > service_role key
# WARNING: Never expose this in client-side code
SUPABASE_SERVICE_ROLE_KEY=

# =============================================================================
# Meilisearch Configuration
# =============================================================================

# Meilisearch host URL (production only — staging uses browse mode)
# Local: http://localhost:7700
# Prod:  https://your-project.meilisearch.io (Meilisearch Cloud)
MEILISEARCH_HOST=http://localhost:7700

# Admin API key for indexing operations (setup, sync, webhook)
# Local: Get from MEILI_MASTER_KEY when starting Meilisearch
# Cloud: Found in Meilisearch Cloud Dashboard > API Keys > Admin API Key
# WARNING: Never expose this in client-side code
MEILISEARCH_ADMIN_API_KEY=

# Search API key for search operations (public, read-only)
# Local: Generate using meilisearch-setup script or Meilisearch API
# Cloud: Found in Meilisearch Cloud Dashboard > API Keys > Search API Key
# This key can only search, not modify indexes
MEILISEARCH_SEARCH_API_KEY=

# =============================================================================
# Optional - Hybrid Search (Semantic Search)
# =============================================================================

# OpenAI API key for hybrid search with embeddings
# Required only if you want semantic search capabilities
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# =============================================================================
# Optional - Supabase Webhook
# =============================================================================

# Secret for authenticating Supabase webhooks (realtime sync)
# Generate a random string: openssl rand -hex 32
# Configure in Supabase Dashboard > Database > Webhooks
SUPABASE_WEBHOOK_SECRET=
